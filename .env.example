# Copia este archivo a .env para configurar el backend (server/).
# Sin ningún valor definido, los correos se envían por Ethereal (buzón de
# prueba, sin configuración) y verás un link "Ver correo de prueba" en la app.
#
# El servidor prueba los métodos de envío en este orden y usa el primero que
# esté configurado (si falla, cae automáticamente al siguiente):
#   1. SMTP directo (MAIL_HOST/PORT/USERNAME/PASSWORD)
#   2. Resend (EMAIL_API_KEY)
#   3. Ethereal (sin configurar nada)

# Puerto del backend (opcional, por defecto 3001)
PORT=3001

# Remitente que verá el destinatario en cualquiera de los tres métodos.
APP_EMAIL_FROM="contacto@tudominio.com"

# --- Opción 1: SMTP directo (tu propio buzón de correo) ---
# Credenciales del servidor SMTP de tu proveedor de correo (Namecheap Private
# Email, Gmail, tu hosting, etc.). MAIL_PORT 587 usa STARTTLS; 465 usa TLS
# implícito.
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Opción 2: Resend (https://resend.com) ---
# Solo se usa si no hay configuración SMTP arriba. El dominio de
# APP_EMAIL_FROM debe estar verificado en https://resend.com/domains, o
# Resend rechaza el envío con un error 403.
EMAIL_API_KEY=
