# Copia este archivo a .env para configurar el backend (server/).

# Puerto del backend (opcional, por defecto 3001)
PORT=3001

# Remitente que verá el destinatario
APP_EMAIL_FROM="contacto@tudominio.com"

# Configuración SMTP (obligatorio)
# Credenciales del servidor SMTP de tu proveedor de correo (Namecheap Private
# Email, Gmail, tu hosting, etc.). MAIL_PORT 587 usa STARTTLS; 465 usa TLS
# implícito.
MAIL_HOST=mail.privateemail.com
MAIL_PORT=587
MAIL_USERNAME=contacto@tudominio.com
MAIL_PASSWORD=tu_contraseña
