# Copia este archivo a .env para configurar el backend (server/).

# Puerto del backend (opcional, por defecto 3001)
PORT=3001

# Remitente que verá el destinatario
# Debe estar verificado en https://resend.com/domains o usar onboarding@resend.dev
APP_EMAIL_FROM="onboarding@resend.dev"

# Resend API Key (obligatorio)
# Obtén tu API key en https://resend.com/api-keys
RESEND_API_KEY=
